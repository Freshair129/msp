{
  "name": "msp-bridge",
  "version": "0.1.0",
  "description": "Stable integration layer for MSP + GKS with pgvector support.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit && node esbuild.config.mjs production",
