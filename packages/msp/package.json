{
  "name": "msp",
  "version": "0.4.0",
  "description": "Memory & Soul Passport — passport-orchestrator over @freshair129/gks, with Knowledge Browser web UI",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "msp-validator": "./dist/validator/cli.js",
    "msp-brain": "./dist/brain/cli.js",
    "msp-mcp-server": "./dist/mcp/bin.js",
    "msp-master-propose": "./dist/master/cli.js",
    "msp-usage": "./dist/usage/cli.js",
    "msp-policy": "./dist/policy/cli.js",
    "msp-vault": "./dist/vault/cli.js",
    "msp-genesis-exec": "./dist/genesis/cli.js",
    "msp-consolidate": "./dist/orchestrator/consolidator/cli.js",
    "msp-candidate": "./dist/memory/candidates/cli.js",
    "msp-auth": "./dist/policy/step-up/cli.js",
    "msp-tag": "./dist/policy/classifiers/cli.js"
  },
  "scripts": {
    "dev": "concurrently \"npm run build:watch\" \"npm run test:watch\"",
    "build": "tsc -p tsconfig.build.json && node ../../scripts/msp/chmod-bins.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "msp:index": "tsx ../../scripts/msp/re-indexer.ts --root=../..",
    "msp:validate": "tsx src/validator/cli.ts --all --root=../..",
    "msp:backlinks": "tsx src/memory/backlinks/cli.ts",
    "msp:check-links": "gks validate --links --root=../..",
    "msp:dispatch": "tsx src/agents/cli.ts",
    "msp:policy": "tsx src/policy/cli.ts",
    "msp:vault": "tsx src/vault/cli.ts",
    "msp:genesis": "tsx src/genesis/cli.ts",
    "msp:hotfix:open": "gks hotfix open",
    "msp:hotfix:close": "gks hotfix close"
  },
  "dependencies": {
    "@aflsolutions/graphology-communities-leiden": "^1.1.1",
    "@freshair129/gks": "*",
    "@modelcontextprotocol/sdk": "^1.6.0",
    "better-sqlite3": "^11.9.1",
    "chalk": "^5.4.1",
    "express": "^4.21.2",
    "graphology": "^0.25.4",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-types": "^0.24.8",
    "node-fetch": "^3.3.2",
    "tree-sitter-python": "^0.25.0",
    "web-tree-sitter": "^0.26.8",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.17",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.1"
  }
}
